@* Content-page heading block: title + optional subtitle, with an optional
   right-aligned action slot (e.g. "+ New role"). Uses the ag-page-head recipe
   (DESIGN.md §4). With no Actions, the title block simply sits at the start of
   the flex row — no extra markup needed for the plain heading-only case. *@

<div class="ag-page-head">
    <div>
        <RadzenText TextStyle="TextStyle.H5" TagName="TagName.H1">@Title</RadzenText>
        @if (!string.IsNullOrWhiteSpace(Subtitle))
        {
            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary-color);">@Subtitle</RadzenText>
        }
    </div>
    @if (Actions is not null)
    {
        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap">
            @Actions
        </RadzenStack>
    }
</div>

@code {
    /// <summary>The page title, rendered as the H1.</summary>
    [Parameter, EditorRequired]
    public string Title { get; set; } = "";

    /// <summary>Optional short description shown under the title.</summary>
    [Parameter]
    public string? Subtitle { get; set; }

    /// <summary>Optional right-aligned action(s), e.g. a primary button.</summary>
    [Parameter]
    public RenderFragment? Actions { get; set; }
}
