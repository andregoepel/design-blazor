@* Reusable inline SVG icon set (stroke-based, inherits currentColor).

   Usage: <AppIcon Name="sun" />  or  <AppIcon Name="moon" Size="16" />
   Icons are decorative by default (aria-hidden); give the surrounding control
   its own accessible label. Add a new glyph by dropping its inner geometry into
   the Glyphs dictionary below. *@

@if (Glyphs.TryGetValue(Name, out var inner))
{
    <svg viewBox="0 0 24 24" width="@Size" height="@Size" fill="none" stroke="currentColor"
         stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        @((MarkupString)inner)
    </svg>
}

@code {
    /// <summary>Glyph key — see <see cref="Glyphs"/> for the available names.</summary>
    [Parameter, EditorRequired]
    public string Name { get; set; } = string.Empty;

    /// <summary>Rendered width/height in px (icons are square).</summary>
    [Parameter]
    public int Size { get; set; } = 16;

    // Inner geometry for each glyph, drawn on a 24×24 viewBox. Kept as raw markup
    // so the shared <svg> wrapper above owns stroke/size and every caller matches.
    private static readonly IReadOnlyDictionary<string, string> Glyphs = new Dictionary<string, string>
    {
        ["sun"] =
            "<circle cx=\"12\" cy=\"12\" r=\"4\"/>" +
            "<path d=\"M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4\"/>",
        ["monitor"] =
            "<rect x=\"3\" y=\"4\" width=\"18\" height=\"12\" rx=\"2\"/>" +
            "<path d=\"M8 20h8M12 16v4\"/>",
        ["moon"] =
            "<path d=\"M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z\"/>",
        ["edit"] =
            "<path d=\"M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z\"/>",
        ["delete"] =
            "<path d=\"M4 7h16M9 7V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v3M6 7l1 13a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1l1-13M10 11v6M14 11v6\"/>",
        ["search"] =
            "<circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"M21 21l-4.3-4.3\"/>",
        ["more-horizontal"] =
            "<circle cx=\"5\" cy=\"12\" r=\"1\"/><circle cx=\"12\" cy=\"12\" r=\"1\"/><circle cx=\"19\" cy=\"12\" r=\"1\"/>",
        ["plus"] =
