        ["chevron-left"] =
            "<path d=\"M15 18l-6-6 6-6\"/>",
        ["chevron-right"] =
            "<path d=\"M9 18l6-6-6-6\"/>",
        ["key"] =
            "<circle cx=\"7\" cy=\"15\" r=\"4\"/><path d=\"M10 12l9-9M16 6l2 2M18 4l2 2\"/>",
        ["check"] =
            "<path d=\"M20 6L9 17l-5-5\"/>",
        ["x"] =
            "<path d=\"M18 6L6 18M6 6l12 12\"/>",
    };
}
