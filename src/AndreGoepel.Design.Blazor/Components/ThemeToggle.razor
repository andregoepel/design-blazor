@* Light / auto / dark theme switch. Interactive so button clicks reach the
   browser-side agTheme helper that owns data-theme + localStorage. *@
@rendermode InteractiveServer
@using Microsoft.JSInterop
@inject IJSRuntime JS
@inject IServiceProvider Services

<div class="ag-theme-toggle" role="group" aria-label="@T("Theme.GroupLabel")">
    @foreach (var mode in Modes)
    {
        <button type="button"
                class="ag-theme-btn @(mode.Key == _current ? "ag-active" : string.Empty)"
                title="@mode.Title"
                aria-label="@mode.Title"
                aria-pressed="@(mode.Key == _current)"
                @onclick="() => SetAsync(mode.Key)">
            <AppIcon Name="@mode.Icon" Size="14" />
        </button>
    }
</div>

@code {
    private string _current = "auto";

    private sealed record Mode(string Key, string Icon, string Title);

    // Instance-level, not a static array: the titles are culture-dependent, so they
    // have to be resolved per render rather than once per process.
    private Mode[] Modes =>
        [
            new("light", "sun", T("Theme.Light")),
            new("auto", "monitor", T("Theme.Auto")),
            new("dark", "moon", T("Theme.Dark")),
        ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            _current = await JS.InvokeAsync<string>("agTheme.get");
            StateHasChanged();
        }
        catch (JSException)
        {
            // Script not ready yet (e.g. during prerender) — keep the default.
        }
    }

    private async Task SetAsync(string mode) =>
        _current = await JS.InvokeAsync<string>("agTheme.set", mode);

    // Resolved through IServiceProvider rather than an injected IStringLocalizer so the
    // component still renders on a host (or bUnit test) without localization registered.
    private string T(string key) => Services.DesignText(key);
}
