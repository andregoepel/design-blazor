@inherits LocalizedComponentBase

@* Light / auto / dark theme switch.

   Deliberately NOT interactive. Each button carries a plain onclick that calls
   the browser-side agTheme helper (theme.js), which owns data-theme +
   localStorage — so the toggle also works on statically rendered pages (e.g.
   the auth pages hosted in LoginShell) and needs no circuit. The active state
   is applied by CSS from the data-theme-pref attribute agTheme maintains on
   <html>; aria-pressed is stamped by theme.js for the same reason. *@

<div class="ag-theme-toggle" role="group" aria-label="@T("Theme.GroupLabel")">
    @foreach (var mode in Modes)
    {
        <button type="button"
                class="ag-theme-btn"
                data-mode="@mode.Key"
                title="@mode.Title"
                aria-label="@mode.Title"
                onclick="agTheme.set('@mode.Key')">
            <AppIcon Name="@mode.Icon" Size="14" />
        </button>
    }
</div>

@code {
    private sealed record Mode(string Key, string Icon, string Title);

    // Instance-level, not a static array: the titles are culture-dependent, so they
    // have to be resolved per render rather than once per process.
    private Mode[] Modes =>
        [
            new("light", "sun", T("Theme.Light")),
            new("auto", "monitor", T("Theme.Auto")),
            new("dark", "moon", T("Theme.Dark")),
        ];
}
