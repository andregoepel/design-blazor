@* Sets the document <title> and, for pages inside an AppShell, the topbar
   breadcrumb (via the cascaded BreadcrumbState). The document title is
   "{Title} – {brand}", where the brand is an explicit Suffix if given, else the
   BrandName configured via AddDesignBlazor(o => o.BrandName = …). Pass neither
   for a plain title. *@
@using Microsoft.Extensions.DependencyInjection
@using Microsoft.Extensions.Options
@inject IServiceProvider Services

<PageTitle>@DocumentTitle</PageTitle>

@code {
    /// <summary>The page-specific title, e.g. "Profile".</summary>
    [Parameter, EditorRequired]
    public string Title { get; set; } = default!;

    /// <summary>
    /// Optional topbar breadcrumb, e.g. "Account / Profile". When omitted the
    /// <see cref="Title"/> is used. Ignored where no <see cref="BreadcrumbState"/>
    /// is cascaded (e.g. pages outside the shell).
    /// </summary>
    [Parameter]
    public string? Breadcrumb { get; set; }

    /// <summary>
    /// Explicit brand suffix for this page, appended as "{Title} – {Suffix}".
    /// Overrides the host-configured <see cref="DesignBlazorOptions.BrandName"/>.
    /// </summary>
    [Parameter]
    public string? Suffix { get; set; }

    // Supplied by AppShell; null under layouts without a topbar.
    [CascadingParameter]
    private BreadcrumbState? BreadcrumbState { get; set; }

    // Resolve optionally: the title must still render when the host (or a test) has
    // not registered options, in which case no brand suffix is appended.
    private string? BrandName =>
        Services.GetService<IOptions<DesignBlazorOptions>>()?.Value.BrandName;

    private string DocumentTitle => Compose(Title, Suffix, BrandName);

    /// <summary>
    /// Builds the document title: "{title} – {brand}", preferring an explicit
    /// <paramref name="suffix"/> over the configured <paramref name="brandName"/>;
    /// with neither, just the title.
    /// </summary>
    internal static string Compose(string title, string? suffix, string? brandName)
    {
        var brand = !string.IsNullOrWhiteSpace(suffix) ? suffix : brandName;
        return string.IsNullOrWhiteSpace(brand) ? title : $"{title} – {brand}";
    }

    protected override void OnParametersSet() => BreadcrumbState?.Set(Breadcrumb ?? Title);
}
