@* A single feature-toggle row: label + description on the left, a
   RadzenSwitch on the right (the ag-toggle-row recipe). Stack several inside
   a RadzenCard — the last row's bottom border drops automatically. Bind Value
   two-way with @bind-Value. *@

<div class="ag-toggle-row">
    <div class="ag-toggle-row-text">
        <span class="ag-toggle-row-label">@Label</span>
        @if (!string.IsNullOrWhiteSpace(Description))
        {
            <span class="ag-toggle-row-description">@Description</span>
        }
    </div>
    <RadzenSwitch Value="Value" ValueChanged="OnValueChanged" Disabled="Disabled" />
</div>

@code {
    /// <summary>The setting's name, e.g. "Two-factor authentication".</summary>
    [Parameter, EditorRequired]
    public string Label { get; set; } = "";

    /// <summary>Optional muted copy shown under the label.</summary>
    [Parameter]
    public string? Description { get; set; }

    /// <summary>Whether the setting is on. Bind with <c>@@bind-Value</c>.</summary>
    [Parameter]
    public bool Value { get; set; }

    /// <summary>Raised when the switch is toggled.</summary>
    [Parameter]
    public EventCallback<bool> ValueChanged { get; set; }

    /// <summary>Disables the switch.</summary>
    [Parameter]
    public bool Disabled { get; set; }

    private async Task OnValueChanged(bool value)
    {
        Value = value;
        await ValueChanged.InvokeAsync(value);
    }
}
