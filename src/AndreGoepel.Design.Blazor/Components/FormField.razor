@* Label-above form field (DESIGN.md §5 "Forms"): a label over the control, full
   width. Put the input (and any validators) in ChildContent; set For to the
   input's Name so the label links to it. Never use RadzenFormField — its floating
   label doesn't match the design. LabelActions is an optional trailing slot on
   the label row (e.g. a "Forgot password?" link next to "Password"). *@

<RadzenStack Gap="0.4rem">
    @if (LabelActions is null)
    {
        @RenderLabel
    }
    else
    {
        <div class="ag-field-head">
            @RenderLabel
            @LabelActions
        </div>
    }
    @ChildContent
    @if (!string.IsNullOrWhiteSpace(Hint))
    {
        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
            @Hint
        </RadzenText>
    }
</RadzenStack>

@code {
    /// <summary>The field label.</summary>
    [Parameter, EditorRequired]
    public string Label { get; set; } = "";

    /// <summary>The <c>Name</c> of the control this labels (links the label to it).</summary>
    [Parameter]
    public string? For { get; set; }

    /// <summary>The control, plus any validators.</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>Optional muted help text shown under the control.</summary>
    [Parameter]
    public string? Hint { get; set; }

    /// <summary>Whether to show a red asterisk after the label. Purely visual — pair
    /// it with a <c>RadzenRequiredValidator</c> on the control for actual validation.</summary>
    [Parameter]
    public bool Required { get; set; }

    /// <summary>Optional trailing content on the label row, right-aligned next to the
    /// label (e.g. a "Forgot password?" <c>RadzenLink</c>). Omit for a plain label.</summary>
    [Parameter]
    public RenderFragment? LabelActions { get; set; }

    private RenderFragment RenderLabel =>
        @<RadzenLabel Component="@For">
            @Label
            @if (Required)
            {
                <span class="ag-required" aria-hidden="true">*</span>
            }
        </RadzenLabel>;
}
