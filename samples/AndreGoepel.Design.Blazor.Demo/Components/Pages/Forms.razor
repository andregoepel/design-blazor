@page "/forms"
@rendermode InteractiveServer
@inject NotificationService Notifications

<AppPageTitle Title="Forms" Breadcrumb="Components / Forms" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">
        <PageHeader Title="Forms"
                    Subtitle="CardForm wraps the card + template form + action footer; FormField is the label-above field. Submit only fires when validation passes." />

        <CardForm TItem="Model" Data="_model" Submit="OnSubmit" Cancel="OnCancel"
                  SubmitText="Save changes" IsBusy="_saving" BusyText="Saving…">
            <div class="ag-form-grid">
                <FormField Label="First name" For="FirstName">
                    <RadzenTextBox @bind-Value="_model.FirstName" Name="FirstName" Style="width:100%" />
                    <RadzenRequiredValidator Component="FirstName" Text="First name is required" />
                </FormField>
                <FormField Label="Last name" For="LastName">
                    <RadzenTextBox @bind-Value="_model.LastName" Name="LastName" Style="width:100%" />
                    <RadzenRequiredValidator Component="LastName" Text="Last name is required" />
                </FormField>
            </div>

            <FormField Label="Email" For="Email" Hint="We'll only use this to contact you.">
                <RadzenTextBox @bind-Value="_model.Email" Name="Email" Placeholder="name@example.com" Style="width:100%" />
                <RadzenRequiredValidator Component="Email" Text="Email is required" />
                <RadzenEmailValidator Component="Email" Text="That is not a valid email" />
            </FormField>

            <FormField Label="Role" For="Role">
                <RadzenDropDown @bind-Value="_model.Role" Data="_roles" Name="Role" Style="width:100%" />
            </FormField>

            <FormField Label="Notes" For="Notes">
                <RadzenTextArea @bind-Value="_model.Notes" Name="Notes" Rows="3" Style="width:100%" />
            </FormField>
        </CardForm>
    </RadzenStack>
</div>

@code {
    private readonly Model _model = new();
    private readonly string[] _roles = ["Viewer", "Editor", "Administrator"];
    private bool _saving;

    private async Task OnSubmit()
    {
        _saving = true;
        await Task.Delay(900); // simulate a save round-trip so the busy state is visible
        _saving = false;
        Notifications.Notify(NotificationSeverity.Success, "Saved", $"Form submitted for {_model.Email}.");
    }

    private void OnCancel()
    {
        _model.FirstName = _model.LastName = _model.Email = _model.Notes = null;
        _model.Role = "Viewer";
        Notifications.Notify(NotificationSeverity.Info, "Cancelled", "The form was reset.");
    }

    private sealed class Model
    {
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? Email { get; set; }
        public string Role { get; set; } = "Viewer";
        public string? Notes { get; set; }
    }
}
