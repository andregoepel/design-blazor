@page "/forms"
@rendermode InteractiveServer
@inject NotificationService Notifications
@inject IStringLocalizer<Strings> L

<AppPageTitle Title="@L["Forms.PageTitle"]" Breadcrumb="@L["Forms.Breadcrumb"]" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">
        <PageHeader Title="@L["Forms.PageTitle"]"
                    Subtitle="@L["Forms.Subtitle"]" />

        @* SubmitText/BusyText are left unset — CardForm's own localized defaults
           ("Save changes"/"Saving…" or their German equivalents) apply. *@
        <CardForm TItem="Model" Data="_model" Submit="OnSubmit" Cancel="OnCancel" IsBusy="_saving">
            <div class="ag-form-grid">
                <FormField Label="@L["Forms.FirstName"]" For="FirstName">
                    <RadzenTextBox @bind-Value="_model.FirstName" Name="FirstName" Style="width:100%" />
                    <RadzenRequiredValidator Component="FirstName" Text="@L["Forms.FirstNameRequired"]" />
                </FormField>
                <FormField Label="@L["Forms.LastName"]" For="LastName">
                    <RadzenTextBox @bind-Value="_model.LastName" Name="LastName" Style="width:100%" />
                    <RadzenRequiredValidator Component="LastName" Text="@L["Forms.LastNameRequired"]" />
                </FormField>
            </div>

            <FormField Label="@L["Forms.Email"]" For="Email" Hint="@L["Forms.EmailHint"]">
                <RadzenTextBox @bind-Value="_model.Email" Name="Email" Placeholder="name@example.com" Style="width:100%" />
                <RadzenRequiredValidator Component="Email" Text="@L["Forms.EmailRequired"]" />
                <RadzenEmailValidator Component="Email" Text="@L["Forms.EmailInvalid"]" />
            </FormField>

            <FormField Label="@L["Forms.Role"]" For="Role">
                <RadzenDropDown @bind-Value="_model.Role" Data="RoleOptions" TextProperty="Label" ValueProperty="Key" Name="Role" Style="width:100%" />
            </FormField>

            <FormField Label="@L["Forms.Notes"]" For="Notes">
                <RadzenTextArea @bind-Value="_model.Notes" Name="Notes" Rows="3" Style="width:100%" />
            </FormField>
        </CardForm>

        @* Danger="true" swaps the submit button to ButtonStyle.Danger — for a
           form whose primary action is destructive (e.g. account deletion). *@
        <CardForm TItem="DeleteAccountModel" Data="_deleteAccountModel" Submit="OnDeleteAccount"
                  Title="@L["Forms.DeleteAccountTitle"]" SubmitText="@L["Forms.DeleteAccountSubmit"]" Danger="true">
            <FormField Label="@L["Forms.DeleteAccountConfirm"]" For="Confirm">
                <RadzenTextBox @bind-Value="_deleteAccountModel.Confirm" Name="Confirm" Style="width:100%" />
                <RadzenRequiredValidator Component="Confirm" Text="@L["Forms.DeleteAccountConfirmRequired"]" />
            </FormField>
        </CardForm>
    </RadzenStack>
</div>

@code {
    private sealed record RoleOption(string Key, string Label);

    // Stable keys, independent of the displayed (localized) label — see the same
    // pattern in DataGrid.razor's StatusOptions.
    private List<RoleOption> RoleOptions =>
        [
            new("viewer", L["Forms.Viewer"]),
            new("editor", L["Forms.Editor"]),
            new("admin", L["Forms.Administrator"]),
        ];

    private readonly Model _model = new();
    private bool _saving;
    private readonly DeleteAccountModel _deleteAccountModel = new();

    private async Task OnSubmit()
    {
        _saving = true;
        await Task.Delay(900); // simulate a save round-trip so the busy state is visible
        _saving = false;
        Notifications.Notify(NotificationSeverity.Success, L["Forms.SavedNotificationTitle"], L["Forms.SavedNotificationMessage", _model.Email ?? ""]);
    }

    private void OnCancel()
    {
        _model.FirstName = _model.LastName = _model.Email = _model.Notes = null;
        _model.Role = "viewer";
        Notifications.Notify(NotificationSeverity.Info, L["Forms.CancelledNotificationTitle"], L["Forms.CancelledNotificationMessage"]);
    }

    private void OnDeleteAccount()
    {
        _deleteAccountModel.Confirm = null;
        Notifications.Notify(NotificationSeverity.Success, L["Forms.DeleteAccountNotificationTitle"], L["Forms.DeleteAccountNotificationMessage"]);
    }

    private sealed class Model
    {
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? Email { get; set; }
        public string Role { get; set; } = "viewer";
        public string? Notes { get; set; }
    }

    private sealed class DeleteAccountModel
    {
        public string? Confirm { get; set; }
    }
}
