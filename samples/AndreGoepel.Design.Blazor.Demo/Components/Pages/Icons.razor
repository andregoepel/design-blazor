@page "/icons"

<AppPageTitle Title="Icons" Breadcrumb="Getting started / Icons" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">
        <PageHeader Title="Icons"
                    Subtitle="The AppIcon inline-SVG set (stroke-based, inherits currentColor)." />

        <RadzenCard>
            <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(120px,1fr)); gap:0.75rem;">
                @foreach (var name in Glyphs)
                {
                    <div style="display:flex; flex-direction:column; align-items:center; gap:0.4rem; padding:0.9rem; border:1px solid var(--ag-border); border-radius:8px;">
                        <AppIcon Name="@name" Size="24" />
                        <span class="ag-mono" style="font-size:12px;">@name</span>
                    </div>
                }
            </div>
        </RadzenCard>
    </RadzenStack>
</div>

@code {
    // Keep in sync with AppIcon.Glyphs.
    private static readonly string[] Glyphs =
    [
        "sun",
        "monitor",
        "moon",
        "edit",
        "delete",
        "search",
        "more-horizontal",
        "plus",
        "chevron-left",
        "chevron-right",
        "key",
        "check",
        "x",
    ];
}
