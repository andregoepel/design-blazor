@page "/data-grid"
@rendermode InteractiveServer
@inject DialogService Dialogs
@inject ContextMenuService ContextMenu
@inject NotificationService Notifications

<AppPageTitle Title="Data grid" Breadcrumb="Components / Data grid" Suffix="Design Blazor" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">
        <PageHeader Title="Data grid"
                    Subtitle="The in-card grid recipe: DataCard + GridToolbar (search + count), name/id cells, status badges, and a row-action overflow menu. RowActions/IconButton land in issue #11.">
            <Actions>
                <RadzenButton Text="New user" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="AddOne" />
            </Actions>
        </PageHeader>

        <DataCard>
            <GridToolbar @bind-Search="_search" SearchPlaceholder="Search users…"
                         Count="@($"{Filtered.Count} of {_users.Count}")" />

            @if (Filtered.Count == 0)
            {
                <div class="rz-p-4 rz-p-md-6">
                    <EmptyState Icon="@("👤︎")" Title="No users match your search"
                                Text="Try a different term, or clear the search box." />
                </div>
            }
            else
            {
                <RadzenDataGrid TItem="User" Data="Filtered" Density="Density.Compact"
                                AllowFiltering="false" AllowColumnResize="false"
                                AllowPaging="true" PageSize="8" AllowSorting="true">
                    <Columns>
                        <RadzenDataGridColumn TItem="User" Property="Name" Title="User">
                            <Template Context="u">
                                <div style="display:flex; flex-direction:column; gap:2px;">
                                    <span class="ag-cell-name">@u.Name</span>
                                    <span class="ag-cell-id">@u.Id</span>
                                </div>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="User" Property="Email" Title="Email" />
                        <RadzenDataGridColumn TItem="User" Property="Active" Title="Status" Width="120px">
                            <Template Context="u">
                                @if (u.Active)
                                {
                                    <StatusBadge Text="Active" Variant="BadgeVariant.Success" />
                                }
                                else
                                {
                                    <StatusBadge Text="Disabled" Variant="BadgeVariant.Danger" />
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="User" Title="" Width="160px" TextAlign="TextAlign.End" Sortable="false">
                            <Template Context="u">
                                <RowActions>
                                    <RadzenButton Text="Edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                                  Click="@(() => Edit(u))" />
                                    <IconButton Icon="more_horiz" Title="More actions" Click="@(args => OpenRowMenu(args, u))" />
                                </RowActions>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            }
        </DataCard>
    </RadzenStack>
</div>

@code {
    private string _search = string.Empty;
    private readonly List<User> _users = Seed();

    private List<User> Filtered =>
        string.IsNullOrWhiteSpace(_search)
            ? _users
            : _users.Where(u =>
                  u.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                  u.Email.Contains(_search, StringComparison.OrdinalIgnoreCase))
              .ToList();

    private void AddOne()
    {
        var n = _users.Count + 1;
        _users.Add(new User($"USR-{n:000}", $"New User {n}", $"user{n}@example.com", true));
        Notifications.Notify(NotificationSeverity.Success, "Added", "A demo user was added.");
    }

    private void Edit(User u) =>
        Notifications.Notify(NotificationSeverity.Info, "Edit", $"Would open the editor for {u.Name}.");

    private void OpenRowMenu(MouseEventArgs args, User u)
    {
        var items = new List<ContextMenuItem>
        {
            new() { Text = u.Active ? "Disable" : "Enable", Value = "toggle", Icon = "sync" },
            new() { Text = "Delete", Value = "delete", Icon = "delete", IconColor = "var(--ag-danger)" },
        };

        ContextMenu.Open(args, items, async e =>
        {
            ContextMenu.Close();
            switch (e.Value as string)
            {
                case "toggle":
                    u.Active = !u.Active;
                    StateHasChanged();
                    break;
                case "delete":
                    await DeleteAsync(u);
                    break;
            }
        });
    }

    private async Task DeleteAsync(User u)
    {
        var ok = await Dialogs.Confirm(
            $"Delete {u.Name}? This cannot be undone.",
            "Delete user",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });

        if (ok == true)
        {
            _users.Remove(u);
            Notifications.Notify(NotificationSeverity.Success, "Deleted", $"{u.Name} was removed.");
            StateHasChanged();
        }
    }

    private static List<User> Seed() =>
    [
        new("USR-001", "Ada Lovelace", "ada@example.com", true),
        new("USR-002", "Alan Turing", "alan@example.com", true),
        new("USR-003", "Grace Hopper", "grace@example.com", false),
        new("USR-004", "Katherine Johnson", "katherine@example.com", true),
        new("USR-005", "Edsger Dijkstra", "edsger@example.com", true),
        new("USR-006", "Barbara Liskov", "barbara@example.com", false),
        new("USR-007", "Donald Knuth", "donald@example.com", true),
        new("USR-008", "Margaret Hamilton", "margaret@example.com", true),
        new("USR-009", "Linus Torvalds", "linus@example.com", true),
    ];

    private sealed class User(string id, string name, string email, bool active)
    {
        public string Id { get; } = id;
        public string Name { get; } = name;
        public string Email { get; } = email;
        public bool Active { get; set; } = active;
    }
}
