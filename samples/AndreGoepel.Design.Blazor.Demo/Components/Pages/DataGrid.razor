@page "/data-grid"
@rendermode InteractiveServer
@inject ConfirmService Confirm
@inject ContextMenuService ContextMenu
@inject NotificationService Notifications
@inject IStringLocalizer<Strings> L

<AppPageTitle Title="@L["DataGrid.PageTitle"]" Breadcrumb="@L["DataGrid.Breadcrumb"]" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">
        <PageHeader Title="@L["DataGrid.PageTitle"]"
                    Subtitle="@L["DataGrid.Subtitle"]">
            <Actions>
                <RadzenButton Text="@L["DataGrid.NewUser"]" Icon="add" ButtonStyle="ButtonStyle.Primary" Click="AddOne" />
            </Actions>
        </PageHeader>

        <FilterBar OnApply="ApplyFilters">
            <ChildContent>
                <FormField Label="@L["DataGrid.StatusLabel"]" For="StatusFilter">
                    <RadzenDropDown @bind-Value="_pendingStatus" Data="StatusOptions" TextProperty="Label" ValueProperty="Key"
                                    Name="StatusFilter" Style="min-width: 12rem;" />
                </FormField>
            </ChildContent>
            <Actions>
                <RadzenButton Text="@L["DataGrid.Reset"]" Icon="restart_alt" ButtonStyle="ButtonStyle.Light" Click="ResetFilters" />
            </Actions>
        </FilterBar>

        <DataCard>
            <GridToolbar @bind-Search="_search" SearchPlaceholder="@L["DataGrid.SearchUsers"]"
                         Count="@L["DataGrid.Count", Filtered.Count, _users.Count]" />

            @if (Filtered.Count == 0)
            {
                <div class="rz-p-4 rz-p-md-6">
                    <EmptyState Icon="@("👤︎")" Title="@L["DataGrid.NoUsersMatch"]"
                                Text="@L["DataGrid.TryDifferentTerm"]" />
                </div>
            }
            else
            {
                <RadzenDataGrid TItem="User" Data="Filtered" Density="Density.Compact"
                                AllowFiltering="false" AllowColumnResize="false"
                                AllowPaging="true" PageSize="8" AllowSorting="true">
                    <Columns>
                        <RadzenDataGridColumn TItem="User" Property="Name" Title="@L["DataGrid.UserColumn"]">
                            <Template Context="u">
                                <div style="display:flex; flex-direction:column; gap:2px;">
                                    <span class="ag-cell-name">@u.Name</span>
                                    <span class="ag-cell-id">@u.Id</span>
                                </div>
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="User" Property="Email" Title="@L["DataGrid.EmailColumn"]" />
                        <RadzenDataGridColumn TItem="User" Property="Active" Title="@L["DataGrid.StatusColumn"]" Width="120px">
                            <Template Context="u">
                                @if (u.Active)
                                {
                                    <StatusBadge Text="@L["DataGrid.Active"]" Variant="BadgeVariant.Success" />
                                }
                                else
                                {
                                    <StatusBadge Text="@L["DataGrid.Disabled"]" Variant="BadgeVariant.Danger" />
                                }
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="User" Title="" Width="160px" TextAlign="TextAlign.End" Sortable="false">
                            <Template Context="u">
                                <RowActions>
                                    <RadzenButton Text="@L["DataGrid.Edit"]" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                                  Click="@(() => Edit(u))" />
                                    <IconButton Icon="more_horiz" Title="@L["DataGrid.MoreActions"]" Click="@(args => OpenRowMenu(args, u))" />
                                </RowActions>
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            }
        </DataCard>

        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
            @((MarkupString)L["DataGrid.EmptyTextCaption"].Value)
        </RadzenText>
        <DataCard>
            <RadzenDataGrid TItem="User" Data="@(new List<User>())" EmptyText="@L["DataGrid.NoArchivedUsers"]"
                            Density="Density.Compact" AllowPaging="false">
                <Columns>
                    <RadzenDataGridColumn TItem="User" Property="Name" Title="@L["DataGrid.UserColumn"]" />
                    <RadzenDataGridColumn TItem="User" Property="Email" Title="@L["DataGrid.EmailColumn"]" />
                </Columns>
            </RadzenDataGrid>
        </DataCard>
    </RadzenStack>
</div>

@code {
    private sealed record StatusOption(string Key, string Label);

    // Stable, culture-invariant keys for the filter's own comparisons — the dropdown
    // shows StatusOption.Label (localized), but "all"/"active"/"disabled" must not
    // change with the UI language or the equality checks below would stop matching.
    private List<StatusOption> StatusOptions =>
        [
            new("all", L["DataGrid.All"]),
            new("active", L["DataGrid.Active"]),
            new("disabled", L["DataGrid.Disabled"]),
        ];

    private string _search = string.Empty;
    private readonly List<User> _users = Seed();

    private string _pendingStatus = "all"; // bound to the dropdown
    private string _appliedStatus = "all"; // committed on Apply

    private List<User> Filtered =>
        _users
            .Where(u =>
                string.IsNullOrWhiteSpace(_search)
                || u.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
                || u.Email.Contains(_search, StringComparison.OrdinalIgnoreCase)
            )
            .Where(u =>
                _appliedStatus == "all"
                || (_appliedStatus == "active" && u.Active)
                || (_appliedStatus == "disabled" && !u.Active)
            )
            .ToList();

    private void ApplyFilters() => _appliedStatus = _pendingStatus;

    private void ResetFilters()
    {
        _pendingStatus = "all";
        _appliedStatus = "all";
    }

    private void AddOne()
    {
        var n = _users.Count + 1;
        _users.Add(new User($"USR-{n:000}", $"New User {n}", $"user{n}@example.com", true));
        Notifications.Notify(NotificationSeverity.Success, L["DataGrid.AddedNotificationTitle"], L["DataGrid.AddedNotificationMessage"]);
    }

    private void Edit(User u) =>
        Notifications.Notify(NotificationSeverity.Info, L["DataGrid.EditNotificationTitle"], L["DataGrid.EditNotificationMessage", u.Name]);

    private void OpenRowMenu(MouseEventArgs args, User u)
    {
        var items = new List<ContextMenuItem>
        {
            new() { Text = u.Active ? L["DataGrid.Disable"] : L["DataGrid.Enable"], Value = "toggle", Icon = "sync" },
            new() { Text = L["DataGrid.DeleteAction"], Value = "delete", Icon = "delete", IconColor = "var(--ag-danger)" },
        };

        ContextMenu.Open(args, items, async e =>
        {
            ContextMenu.Close();
            switch (e.Value as string)
            {
                case "toggle":
                    u.Active = !u.Active;
                    StateHasChanged();
                    break;
                case "delete":
                    await DeleteAsync(u);
                    break;
            }
        });
    }

    private async Task DeleteAsync(User u)
    {
        if (await Confirm.ConfirmDeleteAsync(u.Name))
        {
            _users.Remove(u);
            Notifications.Notify(NotificationSeverity.Success, L["DataGrid.DeletedNotificationTitle"], L["DataGrid.DeletedNotificationMessage", u.Name]);
            StateHasChanged();
        }
    }

    private static List<User> Seed() =>
    [
        new("USR-001", "Ada Lovelace", "ada@example.com", true),
        new("USR-002", "Alan Turing", "alan@example.com", true),
        new("USR-003", "Grace Hopper", "grace@example.com", false),
        new("USR-004", "Katherine Johnson", "katherine@example.com", true),
        new("USR-005", "Edsger Dijkstra", "edsger@example.com", true),
        new("USR-006", "Barbara Liskov", "barbara@example.com", false),
        new("USR-007", "Donald Knuth", "donald@example.com", true),
        new("USR-008", "Margaret Hamilton", "margaret@example.com", true),
        new("USR-009", "Linus Torvalds", "linus@example.com", true),
    ];

    private sealed class User(string id, string name, string email, bool active)
    {
        public string Id { get; } = id;
        public string Name { get; } = name;
        public string Email { get; } = email;
        public bool Active { get; set; } = active;
    }
}
