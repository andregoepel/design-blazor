@page "/settings"
@rendermode InteractiveServer
@inject NotificationService Notifications
@inject IStringLocalizer<Strings> L

<AppPageTitle Title="@L["Settings.PageTitle"]" Breadcrumb="@L["Settings.Breadcrumb"]" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">
        <PageHeader Title="@L["Settings.PageTitle"]"
                    Subtitle="@L["Settings.Subtitle"]" />

        <RadzenCard Style="padding: 8px 30px;">
            <SettingToggleRow Label="@L["Settings.SelfServiceRegistration"]"
                               Description="@L["Settings.SelfServiceRegistrationDescription"]"
                               @bind-Value="_registration" />
            <SettingToggleRow Label="@L["Settings.TwoFactorAuth"]"
                               Description="@L["Settings.TwoFactorAuthDescription"]"
                               @bind-Value="_twoFactor" />
            <SettingToggleRow Label="@L["Settings.Passkeys"]"
                               Description="@L["Settings.PasskeysDescription"]"
                               @bind-Value="_passkeys" Disabled="true" />
        </RadzenCard>

        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary-color);">
            @L["Settings.CurrentValues", _registration, _twoFactor, _passkeys]
        </RadzenText>
    </RadzenStack>
</div>

@code {
    private bool _registration = true;
    private bool _twoFactor = true;
    private bool _passkeys;
}
