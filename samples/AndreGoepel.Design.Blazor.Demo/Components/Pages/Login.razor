@page "/login"
@layout LoginLayout
@rendermode InteractiveServer
@inject IStringLocalizer<Strings> L

<AppPageTitle Title="@L["Login.PageTitle"]" />

<div class="ag-login-head">
    <RadzenText TagName="TagName.H1" TextStyle="TextStyle.H4" Text="@L["Login.WelcomeBack"]" />
    <RadzenText TextStyle="TextStyle.Body2" class="ag-login-sub" Text="@L["Login.FillCredentials"]" />
</div>

<RadzenTemplateForm TItem="Model" Data="_model" Submit="OnSubmit">
    <RadzenStack Gap="1.25rem">
        <FormField Label="@L["Login.Email"]" For="Email">
            <RadzenTextBox @bind-Value="_model.Email" Name="Email" Placeholder="name@example.com" Style="width:100%" />
            <RadzenRequiredValidator Component="Email" Text="@L["Login.EmailRequired"]" />
        </FormField>
        @* LabelActions puts the "Forgot password?" link on the label row, right-aligned next to "Password". *@
        <FormField Label="@L["Login.Password"]" For="Password">
            <LabelActions>
                <RadzenLink Path="" Text="@L["Login.ForgotPassword"]" class="ag-field-head-link" />
            </LabelActions>
            <ChildContent>
                <RadzenPassword @bind-Value="_model.Password" Name="Password" Style="width:100%" />
                <RadzenRequiredValidator Component="Password" Text="@L["Login.PasswordRequired"]" />
            </ChildContent>
        </FormField>

        <div class="ag-login-actions">
            <RadzenButton Text="@L["Login.LogIn"]" ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Style="width:100%" />
        </div>
    </RadzenStack>
</RadzenTemplateForm>

<div class="ag-login-footer-links">
    <span class="ag-login-resend">@L["Login.NoAccount"] <RadzenLink Path="" Text="@L["Login.BackToOverview"]" /></span>
</div>

@code {
    private readonly Model _model = new();

    private void OnSubmit()
    {
        // Demo only — no authentication happens here.
    }

    private sealed class Model
    {
        public string? Email { get; set; }
        public string? Password { get; set; }
    }
}
