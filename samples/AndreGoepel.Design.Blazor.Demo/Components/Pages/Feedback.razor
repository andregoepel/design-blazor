@page "/feedback"
@rendermode InteractiveServer
@inject NotificationService Notifications
@inject IStringLocalizer<Strings> L

<AppPageTitle Title="@L["Feedback.PageTitle"]" Breadcrumb="@L["Feedback.Breadcrumb"]" />

<div class="rz-p-4 rz-p-md-6">
    <RadzenStack Gap="1.5rem">
        <PageHeader Title="@L["Feedback.PageTitle"]"
                    Subtitle="@L["Feedback.Subtitle"]" />

        <RadzenStack Gap="0.75rem">
            <RadzenAlert AlertStyle="AlertStyle.Info" ShowIcon="true" AllowClose="false">@L["Feedback.InfoBanner"]</RadzenAlert>
            <RadzenAlert AlertStyle="AlertStyle.Success" ShowIcon="true" AllowClose="false">@L["Feedback.SuccessBanner"]</RadzenAlert>
            <RadzenAlert AlertStyle="AlertStyle.Warning" ShowIcon="true" AllowClose="false">@L["Feedback.WarningBanner"]</RadzenAlert>
            <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true" AllowClose="false">@L["Feedback.DangerBanner"]</RadzenAlert>
        </RadzenStack>

        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H6" TagName="TagName.H2">@L["Feedback.ToastNotifications"]</RadzenText>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" Wrap="FlexWrap.Wrap">
                    <RadzenButton Text="@L["Feedback.Info"]" ButtonStyle="ButtonStyle.Light" Click="@(() => Notify(NotificationSeverity.Info))" />
                    <RadzenButton Text="@L["Feedback.Success"]" ButtonStyle="ButtonStyle.Success" Click="@(() => Notify(NotificationSeverity.Success))" />
                    <RadzenButton Text="@L["Feedback.Warning"]" ButtonStyle="ButtonStyle.Warning" Click="@(() => Notify(NotificationSeverity.Warning))" />
                    <RadzenButton Text="@L["Feedback.Error"]" ButtonStyle="ButtonStyle.Danger" Click="@(() => Notify(NotificationSeverity.Error))" />
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H6" TagName="TagName.H2">@L["Feedback.InfoBox"]</RadzenText>
                <InfoBox Label="@L["Feedback.NextScheduledRun"]">
                    @L["Feedback.TomorrowAt"] <span class="ag-mono">0 3 * * *</span>
                </InfoBox>
                <InfoBox Label="@L["Feedback.Environment"]" Value="@L["Feedback.Production"]" />
            </RadzenStack>
        </RadzenCard>

        <RadzenCard>
            <RadzenStack Gap="1rem">
                <RadzenText TextStyle="TextStyle.H6" TagName="TagName.H2">@L["Feedback.EmptyState"]</RadzenText>
                <EmptyState Icon="@("🔑︎")" Title="@L["Feedback.NoPasskeys"]"
                            Text="@L["Feedback.PasskeysDescription"]">
                    <Actions>
                        <RadzenButton Text="@L["Feedback.RegisterPasskey"]" Icon="add" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" />
                    </Actions>
                </EmptyState>
            </RadzenStack>
        </RadzenCard>
    </RadzenStack>
</div>

@code {
    private void Notify(NotificationSeverity severity) =>
        Notifications.Notify(severity, TitleFor(severity), L["Feedback.NotificationMessage"]);

    // severity.ToString() would give the English enum name regardless of culture.
    private string TitleFor(NotificationSeverity severity) =>
        severity switch
        {
            NotificationSeverity.Info => L["Feedback.Info"],
            NotificationSeverity.Success => L["Feedback.Success"],
            NotificationSeverity.Warning => L["Feedback.Warning"],
            _ => L["Feedback.Error"],
        };
}
