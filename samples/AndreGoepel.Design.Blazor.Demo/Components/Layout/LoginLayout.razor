@inherits LayoutComponentBase
@inject IStringLocalizer<Strings> L

@* Auth-page layout: centred LoginShell (brand + card) with no sidebar/topbar.
   The page supplies the card contents via @Body. *@

<RadzenComponents @rendermode="InteractiveServer" />

<div class="ag-login-lang">
    <LanguageSwitcher />
</div>

<LoginShell BrandName="Design Blazor">
    <ChildContent>
        @Body
    </ChildContent>
    <Footer>
        @L["Shell.LoginFooterPrefix"] <a href="">@L["Shell.BackToOverview"]</a>
    </Footer>
</LoginShell>

<div id="blazor-error-ui" data-nosnippet>
    @L["Shell.UnhandledError"]
    <a href="." class="reload">@L["Shell.Reload"]</a>
    <span class="dismiss">🗙</span>
</div>
