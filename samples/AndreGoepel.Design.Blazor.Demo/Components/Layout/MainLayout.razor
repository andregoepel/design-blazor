@inherits LayoutComponentBase
@inject IStringLocalizer<Strings> L

@* Radzen hosts (dialog / notification / tooltip / context menu) — rendered once. *@
<RadzenComponents @rendermode="InteractiveServer" />

<AppShell BrandName="Design Blazor">
    <Sidebar>
        <DemoNav />
    </Sidebar>
    <TopbarActions>
        <LanguageSwitcher />
        <ThemeToggle />
    </TopbarActions>
    <SidebarFooter>
        <span class="ag-sidebar-note">@L["Shell.SidebarNote"]</span>
    </SidebarFooter>
    <ChildContent>
        @Body
    </ChildContent>
</AppShell>

<div id="blazor-error-ui" data-nosnippet>
    @L["Shell.UnhandledError"]
    <a href="." class="reload">@L["Shell.Reload"]</a>
    <span class="dismiss">🗙</span>
</div>
